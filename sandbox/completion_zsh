#compdef oc-sandbox

_oc-sandbox() {
  local curcontext="$curcontext" state line
  local -a commands
  commands=(
    'build:Build a container image'
    'run:Run opencode in a sandbox'
    'install:Install oc-sandbox as a global command'
    'uninstall:Uninstall the global oc-sandbox command'
    'completion:Generate shell completion scripts'
  )

  _arguments -C \
    '(-h --help)--help[Show help message]' \
    '1: :->command' \
    '*:: :->args'

  case $state in
  command)
    _describe 'command' commands
    ;;
  args)
    case $words[1] in
    build) _oc-sandbox_build ;;
    run) _oc-sandbox_run ;;
    install) _oc-sandbox_install ;;
    uninstall) _oc-sandbox_uninstall ;;
    completion) _oc-sandbox_completion ;;
    esac
    ;;
  esac
}

_oc-sandbox_build() {
  _arguments \
    '(-I --image)--image[Image name to build]:image:_oc-sandbox_images' \
    '(-f --file)--file[Explicit Containerfile path]:file:_files' \
    '(-F --force)--force[Force rebuild even if image exists]' \
    '(-h --help)--help[Show help message]'
}

_oc-sandbox_run() {
  _arguments \
    '(-I --image)--image[Image to use]:image:_oc-sandbox_images' \
    '(-p --profile)--profile[Opencode profile to activate]:profile:_oc-sandbox_profiles' \
    '--no-ssh[Skip mounting SSH keys]' \
    '--no-auth[Skip mounting auth.json]' \
    '--no-gh-token[Skip GH_TOKEN detection]' \
    '--gh-token[GitHub token]:token:' \
    '--debug[Run /bin/bash instead of opencode]' \
    '(-h --help)--help[Show help message]' \
    ':path:_files -/'
}

_oc-sandbox_install() {
  _arguments \
    '--no-completions[Skip shell completion setup]' \
    '(-h --help)--help[Show help message]'
}

_oc-sandbox_uninstall() {
  _arguments \
    '(-h --help)--help[Show help message]'
}

_oc-sandbox_completion() {
  _arguments \
    ':shell:_oc-sandbox_shells' \
    '--refresh[Force-refresh the completion cache]' \
    '(-I --image)--image[Refresh cache for a specific image only]:image:_oc-sandbox_images' \
    '(-h --help)--help[Show help message]'
}

_oc-sandbox_images() {
  local script_dir="${SCRIPT_DIR:-}"
  if [ -z "$script_dir" ]; then
    # Fallback: derive from oc-sandbox location
    script_dir="$(dirname "$(which oc-sandbox 2>/dev/null || echo "")")"
  fi
  local containerfiles_dir="${script_dir}/containerfiles"
  [[ -d "$containerfiles_dir" ]] || return 0
  local -a images
  local f
  for f in "$containerfiles_dir"/*.Containerfile; do
    [[ -f "$f" ]] || continue
    images+=("${f##*/}")
    images[-1]="${images[-1]%.Containerfile}"
  done
  _values 'image' $images
}

_oc-sandbox_profiles() {
  local profiles_dir="${HOME}/.config/oc-sandbox/profiles"
  [[ -d "$profiles_dir" ]] || return 0

  local -a suggestions
  local profile conf variant_name

  for profile in "$profiles_dir"/*/; do
    [[ -d "$profile" ]] || continue
    [[ -f "$profile/profile.conf" ]] || continue
    suggestions+=("$(basename "$profile")")
    for conf in "$profile"/profile.*.conf; do
      [[ -f "$conf" ]] || continue
      variant_name="${conf##*profile.}"
      variant_name="${variant_name%.conf}"
      suggestions+=("$(basename "$profile"):${variant_name}")
    done
  done
  _values 'profile' $suggestions
}

_oc-sandbox_shells() {
  _values 'shells' zsh
}

compdef _oc-sandbox oc-sandbox
