#!/usr/bin/env bash
set -euo pipefail

# oc-sandbox - Run opencode in a containerized sandbox
# Provides filesystem isolation and permission escalation protection

DATA_DIR="${OC_SANDBOX_DATA_DIR:-${HOME}/.local/share/oc-sandbox}"
CONFIG_DIR="${OC_SANDBOX_CONFIG_DIR:-${HOME}/.config/oc-sandbox}"
CONTAINERFILES_DIR="${DATA_DIR}/containerfiles"
OPENCODE_INSTALL_SHA256_FILE="${DATA_DIR}/opencode-install.sha256"
COMPLETION_ZSH="${DATA_DIR}/completion_zsh"
IMAGE_BASE="localhost/oc-sandbox"
DEFAULT_IMAGE="base"

# Terminal colors
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

usage_main() {
  cat <<EOF
Usage: oc-sandbox <command> [options]

Commands:
    build       Build a container image
    run         Run opencode in a sandbox
    uninstall   Uninstall the global oc-sandbox command
    completion  Generate shell completion scripts

Run 'oc-sandbox <command> --help' for more information on a command.

Examples:
    oc-sandbox build                        # Build base image
    oc-sandbox build --image python         # Build python image
    oc-sandbox run                           # Run with defaults (image: base, profile: from config)
    oc-sandbox run --profile superpowers:gpt4  # Use superpowers profile, gpt4 variant
EOF
}

usage_build() {
  cat <<EOF
Usage: oc-sandbox build [OPTIONS]

Build a container image for the opencode sandbox.

Options:
    -I, --image <NAME>   Image name to build (default: base)
    -F, --force          Force rebuild even if image already exists
    -h, --help           Show this help message
EOF
}

usage_run() {
  cat <<EOF
Usage: oc-sandbox run [OPTIONS] [PATH]

Run opencode in a containerized sandbox with filesystem isolation.

Options:
    -I, --image <NAME>           Image to use (default: base)
    -p, --profile <NAME[:VARIANT]>  Opencode profile to activate (default: from config)
    --no-ssh                     Skip mounting SSH keys from host
    --no-auth                    Skip mounting auth.json from host
    --no-gh-token                Skip GH_TOKEN detection from host
    --gh-token <TOKEN>           Use the provided GitHub token instead of auto-detecting
    --debug                      Run /bin/bash instead of opencode for debugging
    -h, --help                   Show this help message

Arguments:
    PATH   Directory to mount as /workspace (default: current working directory)

Examples:
    oc-sandbox run                              # Run with defaults
    oc-sandbox run --profile superpowers         # Use superpowers profile
    oc-sandbox run -p superpowers:gpt4           # Use gpt4 variant
    oc-sandbox run --image python                # Use python image
EOF
}

usage_uninstall() {
  cat <<EOF
Usage: oc-sandbox uninstall

Uninstall the global oc-sandbox command by removing the symlink
from ~/.local/bin/. Also removes shell completion setup and cache.

Options:
    -h, --help    Show this help message

Examples:
    oc-sandbox uninstall    # Remove symlink, completions, and cache
EOF
}

usage_completion() {
  cat <<EOF
Usage: oc-sandbox completion <shell>

Generate shell completion scripts for oc-sandbox.

Shells:
    zsh         Generate Zsh completion script

Options:
    -h, --help          Show this help message

Examples:
    source <(oc-sandbox completion zsh)    # Enable Zsh completions
EOF
}

cmd_uninstall() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
    -h | --help)
      usage_uninstall
      exit 0
      ;;
    -*)
      error "Unknown option: $1\nUse 'oc-sandbox uninstall --help' for usage information."
      ;;
    *)
      error "Unknown argument: $1\nUse 'oc-sandbox uninstall --help' for usage information."
      ;;
    esac
  done

  local install_path="${HOME}/.local/bin/oc-sandbox"

  if [ ! -e "$install_path" ] && [ ! -L "$install_path" ]; then
    info "Not installed at ${install_path}"
    exit 0
  fi

  rm -f "$install_path"
  info "Uninstalled ${install_path}"

  if [ -d "$DATA_DIR" ]; then
    rm -rf "$DATA_DIR"
    info "Removed data directory ${DATA_DIR}"
  fi

  local cache_dir="${HOME}/.cache/oc-sandbox"
  if [ -d "$cache_dir" ]; then
    rm -rf "$cache_dir" || warn "Could not remove cache directory ${cache_dir}"
    info "Removed completion cache from ${cache_dir}"
  fi

  cleanup_completions
}

error() {
  echo -e "${RED}Error: $1${NC}" >&2
  exit 1
}

warn() {
  echo -e "${YELLOW}Warning: $1${NC}" >&2
}

info() {
  echo -e "${GREEN}$1${NC}"
}

cleanup_completions() {
  local shell
  shell="$(basename "${SHELL:-}")"
  case "$shell" in
  zsh)
    local rc_file="${HOME}/.zshrc"
    local completion_line='source <(oc-sandbox completion zsh)'

    if [ -f "$rc_file" ]; then
      if [ -L "$rc_file" ]; then
        info ".zshrc is a symlink; removing completions from the target file"
      fi

      local tmp_file
      tmp_file=$(mktemp)
      grep -vF "$completion_line" "$rc_file" >"$tmp_file" || true
      cat "$tmp_file" >"$rc_file"
      rm -f "$tmp_file"
      info "Removed shell completions from ${rc_file}"
    fi
    ;;
  esac
}

# Read a value from an INI-style config file
_read_config_value() {
  local file="$1"
  local section="$2"
  local key="$3"

  [ -f "$file" ] || return 0

  local in_section="false"
  local line trimmed key_part value_part

  while IFS= read -r line || [ -n "$line" ]; do
    trimmed="$(echo "$line" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
    [ -z "$trimmed" ] && continue
    [[ "$trimmed" == \#* ]] && continue
    [[ "$trimmed" == \;* ]] && continue

    if [[ "$trimmed" == \[*\] ]]; then
      if [ "$trimmed" = "[$section]" ]; then
        in_section="true"
      else
        in_section="false"
      fi
      continue
    fi

    if [ "$in_section" = "true" ]; then
      key_part="$(echo "$trimmed" | cut -d= -f1 | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
      if [ "$key_part" = "$key" ]; then
        value_part="$(echo "$trimmed" | cut -d= -f2- | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
        printf '%s\n' "$value_part"
        return 0
      fi
    fi
  done <"$file"

  return 0
}

# Expand leading ~, ~/, $HOME, $HOME/, ${HOME}, ${HOME}/ in a path
# shellcheck disable=SC2088
_expand_home() {
  local path="$1"
  case "$path" in
  '~/') path="${HOME}/${path#'~'/}" ;;
  '~') path="$HOME" ;;
  esac
  case "$path" in
  \$HOME/*)
    path="${HOME}/${path#\$HOME/}"
    ;;
  \$HOME)
    path="$HOME"
    ;;
  \$\{HOME\}/*)
    path="${HOME}/${path#\$\{HOME\}/}"
    ;;
  \$\{HOME\})
    path="$HOME"
    ;;
  esac
  echo "$path"
}

_read_mount_config() {
  local file="$1"
  local key="$2"
  _read_config_value "$file" "mounts" "$key"
}

check_podman() {
  if ! command -v podman &>/dev/null; then
    error "podman not found. Please install podman."
  fi
}

# List available profiles from the host profiles directory
list_profiles() {
  local profiles_dir="${CONFIG_DIR}/profiles"
  [[ -d "$profiles_dir" ]] || return 0

  local profile
  for profile in "$profiles_dir"/*/; do
    [[ -d "$profile" ]] || continue
    [[ -f "$profile/profile.conf" ]] || continue
    echo "  - $(basename "$profile")"
  done
}

# Scan profiles including variants for completion
_scan_profiles_with_variants() {
  local profiles_dir="${CONFIG_DIR}/profiles"
  [[ -d "$profiles_dir" ]] || return 0

  local profile conf variant_name
  for profile in "$profiles_dir"/*/; do
    [[ -d "$profile" ]] || continue
    [[ -f "$profile/profile.conf" ]] || continue
    basename "$profile"
    for conf in "$profile"/profile.*.conf; do
      [[ -f "$conf" ]] || continue
      # Skip the default profile.conf — `*` in the glob matches zero chars,
      # so profile.*.conf also matches profile.conf itself.
      [[ "$(basename "$conf")" == "profile.conf" ]] && continue
      variant_name="${conf##*profile.}"
      variant_name="${variant_name%.conf}"
      echo "$(basename "$profile"):${variant_name}"
    done
  done
}

cmd_completion_zsh() {
  cat "$COMPLETION_ZSH"
}

cmd_completion() {
  local shell_arg=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
    -h | --help)
      usage_completion
      exit 0
      ;;
    -*)
      error "Unknown option: $1\nUse 'oc-sandbox completion --help' for usage information."
      ;;
    *)
      if [ -n "$shell_arg" ]; then
        error "Unknown argument: $1\nUse 'oc-sandbox completion --help' for usage information."
      fi
      shell_arg="$1"
      shift
      ;;
    esac
  done

  if [ -z "${shell_arg:-}" ]; then
    error "Shell name required. Use 'oc-sandbox completion --help' for available shells."
  fi

  case "$shell_arg" in
  zsh)
    cmd_completion_zsh
    ;;
  bash)
    echo "Bash completion is not yet implemented. See 'oc-sandbox completion --help' for available shells."
    ;;
  fish)
    echo "Fish completion is not yet implemented. See 'oc-sandbox completion --help' for available shells."
    ;;
  *)
    error "Unknown shell '${shell_arg}'. Available shells: zsh"
    ;;
  esac
}

# Build subcommand
cmd_build() {
  local image_name="$DEFAULT_IMAGE"
  local force="false"

  # Read default_image from config if available
  local config_file="${CONFIG_DIR}/config"
  local configured_image
  configured_image="$(_read_config_value "$config_file" "general" "default_image")"
  if [ -n "$configured_image" ]; then
    image_name="$configured_image"
  fi

  while [[ $# -gt 0 ]]; do
    case "$1" in
    -I | --image)
      if [ -z "${2:-}" ]; then
        error "Option --image requires a value."
      fi
      image_name="$2"
      shift 2
      ;;
    -F | --force)
      force="true"
      shift
      ;;
    -h | --help)
      usage_build
      exit 0
      ;;
    -*)
      error "Unknown option: $1\nUse 'oc-sandbox build --help' for usage information."
      ;;
    *)
      error "Unknown argument: $1\nUse 'oc-sandbox build --help' for usage information."
      ;;
    esac
  done

  check_podman

  CONTAINERFILE="${CONTAINERFILES_DIR}/${image_name}.Containerfile"

  local full_image="${IMAGE_BASE}:${image_name}"

  # Check if image already exists
  if podman image exists "$full_image" 2>/dev/null && [ "$force" != "true" ]; then
    info "Image ${full_image} already exists. Use --force to rebuild."
    exit 0
  fi

  # Validate Containerfile exists
  if [ ! -f "$CONTAINERFILE" ]; then
    error "Containerfile not found at: $CONTAINERFILE"
  fi

  # Read SHA256 checksum from file
  if [ ! -f "$OPENCODE_INSTALL_SHA256_FILE" ]; then
    error "Checksum file not found: $OPENCODE_INSTALL_SHA256_FILE"
  fi
  local sha256
  sha256=$(head -n 1 "$OPENCODE_INSTALL_SHA256_FILE" | tr -d '[:space:]')
  if [ -z "$sha256" ]; then
    error "Checksum file is empty: $OPENCODE_INSTALL_SHA256_FILE"
  fi

  # Build args — only OPENCODE_INSTALL_SHA256
  local build_args=(
    "--build-arg" "OPENCODE_INSTALL_SHA256=${sha256}"
  )

  info "Building container image ${full_image}..."
  if ! podman build \
    "${build_args[@]}" \
    -t "$full_image" \
    -f "$CONTAINERFILE" \
    "$DATA_DIR"; then
    error "Container build failed. See output above for details."
  fi

  # Remove the named volume for this image so next run starts fresh
  local volume_name="oc-sandbox-home-${image_name}"
  if podman volume exists "$volume_name" 2>/dev/null; then
    info "Removing existing volume ${volume_name} to ensure fresh state..."
    podman volume rm "$volume_name" >/dev/null 2>&1 || true
  fi

  info "Image ${full_image} built successfully."
}

# Run subcommand
cmd_run() {
  local image_name="$DEFAULT_IMAGE"
  local profile=""
  local profile_variant=""
  local workspace_path=""
  local no_ssh="false"
  local no_auth="false"
  local debug="false"
  local no_gh_token="false"
  local gh_token=""

  # Read default_image from config if available
  local config_file="${CONFIG_DIR}/config"
  local configured_image
  configured_image="$(_read_config_value "$config_file" "general" "default_image")"
  if [ -n "$configured_image" ]; then
    image_name="$configured_image"
  fi

  while [[ $# -gt 0 ]]; do
    case "$1" in
    -I | --image)
      if [ -z "${2:-}" ]; then
        error "Option --image requires a value."
      fi
      image_name="$2"
      shift 2
      ;;
    -p | --profile)
      if [ -z "${2:-}" ]; then
        error "Option --profile requires a value."
      fi
      profile="$2"
      shift 2
      ;;
    -h | --help)
      usage_run
      exit 0
      ;;
    --no-ssh)
      no_ssh="true"
      shift
      ;;
    --no-auth)
      no_auth="true"
      shift
      ;;
    --no-gh-token)
      no_gh_token="true"
      shift
      ;;
    --gh-token)
      if [ -z "${2:-}" ]; then
        error "Option --gh-token requires a value."
      fi
      gh_token="$2"
      shift 2
      ;;
    --debug)
      debug="true"
      shift
      ;;
    -*)
      error "Unknown option: $1\nUse 'oc-sandbox run --help' for usage information."
      ;;
    *)
      if [ -n "$workspace_path" ]; then
        error "Multiple paths specified. Only one PATH argument is allowed."
      fi
      workspace_path="$1"
      shift
      ;;
    esac
  done

  # Validate --no-gh-token / --gh-token conflict
  if [ "$no_gh_token" = "true" ] && [ -n "$gh_token" ]; then
    error "Cannot use --gh-token with --no-gh-token"
  fi

  # Parse profile:variant syntax
  if [ -n "$profile" ]; then
    profile_variant="${profile#*:}"
    if [ "$profile_variant" = "$profile" ]; then
      profile_variant=""
    else
      profile="${profile%%:*}"
    fi
  fi

  # Validate profile name against path traversal
  if [ -n "$profile" ]; then
    if [[ "$profile" =~ [/\\\.] ]]; then
      error "Profile name must not contain '/', '\\', or '.' characters."
    fi
  fi

  local config_file="${CONFIG_DIR}/config"

  # If no profile from --profile flag, try config default
  if [ -z "$profile" ]; then
    if [ -f "$config_file" ]; then
      profile="$(_read_config_value "$config_file" "general" "default_profile")"
    fi
    if [ -z "$profile" ]; then
      error "No default profile configured and --profile not specified.
Set a default profile in ${config_file:-~/.config/oc-sandbox/config}:
  [general]
  default_profile = superpowers
Or use 'oc-sandbox run --profile <name>' to specify one at runtime."
    fi
  fi

  check_podman

  local full_image="${IMAGE_BASE}:${image_name}"

  # Check if image exists
  if ! podman image exists "$full_image" 2>/dev/null; then
    echo -e "${RED}Error: Image '${full_image}' not found.${NC}" >&2
    echo "" >&2
    echo "Build it first: oc-sandbox build --image ${image_name}" >&2
    exit 1
  fi

  # Validate profile exists on host
  local profiles_dir="${CONFIG_DIR}/profiles"
  local profile_path="${profiles_dir}/${profile}"

  if [ ! -d "$profile_path" ]; then
    echo -e "${RED}Error: Profile '${profile}' not found.${NC}" >&2
    echo "" >&2
    echo "Available profiles:" >&2
    list_profiles >&2
    exit 1
  fi

  if [ ! -f "${profile_path}/profile.conf" ]; then
    error "Profile '${profile}' is missing profile.conf"
  fi

  # If variant specified, verify variant file exists
  if [ -n "$profile_variant" ]; then
    local variant_file="${profile_path}/profile.${profile_variant}.conf"
    if [ ! -f "$variant_file" ]; then
      error "Variant '${profile_variant}' not found for profile '${profile}'"
    fi
  fi

  # Default workspace path to current directory
  if [ -z "$workspace_path" ]; then
    workspace_path="$(pwd)"
  fi

  # Resolve to absolute path and validate existence
  if [ ! -e "$workspace_path" ]; then
    error "PATH does not exist: $workspace_path"
  fi

  if [ ! -d "$workspace_path" ]; then
    error "PATH is not a directory: $workspace_path"
  fi

  workspace_path="$(cd "$workspace_path" && pwd)"

  if [ ! -d "$workspace_path" ]; then
    error "PATH is not a directory: $workspace_path"
  fi

  # Warn if path is outside home directory
  if [[ "$workspace_path" != "$HOME"* ]]; then
    warn "PATH is outside your home directory."
    if [ ! -t 0 ]; then
      error "PATH is outside home directory and stdin is not a terminal. Run from within your home directory."
    fi
    read -r -p "Continue? [y/N] " response
    if [[ "$response" != "y" && "$response" != "Y" ]]; then
      echo "Aborted."
      exit 0
    fi
  fi

  # SSH key auto-detection
  local ssh_mounts=()

  if [ "$no_ssh" = "true" ]; then
    info "Skipping SSH key mount (--no-ssh)"
  else
    local ssh_mount_value
    ssh_mount_value="$(_read_mount_config "$config_file" "ssh_key")"
    local ssh_key=""
    local ssh_dst=""

    if [ -n "$ssh_mount_value" ] && [[ "$ssh_mount_value" == *"|"* ]]; then
      local ssh_src_raw
      ssh_src_raw="$(echo "${ssh_mount_value%%|*}" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
      ssh_dst="$(echo "${ssh_mount_value#*|}" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
      ssh_key="$(_expand_home "$ssh_src_raw")"
    fi

    if [ -z "$ssh_key" ] || [ -z "$ssh_dst" ]; then
      ssh_key="${HOME}/.ssh/id_rsa"
      ssh_dst="/home/sandbox/.ssh/id_rsa"
    fi

    local ssh_pub_key="${ssh_key}.pub"

    if [ -e "$ssh_key" ]; then
      if [ ! -r "$ssh_key" ]; then
        error "Cannot read SSH key at ${ssh_key}. Check file permissions."
      fi
      local mode
      mode=$(stat -c '%a' "$ssh_key" 2>/dev/null || stat -f '%Lp' "$ssh_key" 2>/dev/null)
      if [ -n "$mode" ] && [ $((0$mode & 077)) -ne 0 ]; then
        warn "SSH key at ${ssh_key} has overly permissive permissions (0${mode})."
        warn "SSH may refuse to use it. Consider: chmod 600 ${ssh_key}"
      fi
      ssh_mounts+=("--mount" "type=bind,src=${ssh_key},dst=${ssh_dst},readonly,relabel=private")
      if [ -e "$ssh_pub_key" ]; then
        local pub_dst="${ssh_dst}.pub"
        ssh_mounts+=("--mount" "type=bind,src=${ssh_pub_key},dst=${pub_dst},readonly,relabel=private")
      fi
    else
      warn "SSH key not found at ${ssh_key}. Git SSH operations may not work."
    fi
  fi

  # auth.json auto-detection
  local auth_mount=()

  if [ "$no_auth" = "true" ]; then
    info "Skipping auth.json mount (--no-auth)"
  else
    local auth_mount_value
    auth_mount_value="$(_read_mount_config "$config_file" "auth_json")"
    local auth_src=""
    local auth_dst=""

    if [ -n "$auth_mount_value" ] && [[ "$auth_mount_value" == *"|"* ]]; then
      local auth_src_raw
      auth_src_raw="$(echo "${auth_mount_value%%|*}" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
      auth_dst="$(echo "${auth_mount_value#*|}" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
      auth_src="$(_expand_home "$auth_src_raw")"
    fi

    if [ -z "$auth_src" ] || [ -z "$auth_dst" ]; then
      auth_src="${HOME}/.local/share/opencode/auth.json"
      auth_dst="/home/sandbox/.local/share/opencode/auth.json"
    fi

    if [ -e "$auth_src" ]; then
      if [ ! -r "$auth_src" ]; then
        error "Cannot read auth.json at ${auth_src}. Check file permissions."
      fi
      auth_mount+=("--mount" "type=bind,src=${auth_src},dst=${auth_dst},readonly,relabel=private")
    else
      warn "auth.json not found at ${auth_src}. Authenticated providers may not work."
    fi
  fi

  # .gitignore mount
  local gitignore_mount=()
  if [ -f "${HOME}/.gitignore" ]; then
    gitignore_mount+=("--mount" "type=bind,src=${HOME}/.gitignore,dst=/home/sandbox/.gitignore,readonly,relabel=private")
  fi

  # GH_TOKEN auto-detection
  local gh_token_env=()

  if [ "$no_gh_token" = "true" ]; then
    info "Skipping GH_TOKEN detection (--no-gh-token)"
  elif [ -n "$gh_token" ]; then
    gh_token_env+=("--env" "GH_TOKEN=${gh_token}")
  else
    if ! command -v gh &>/dev/null; then
      warn "gh CLI not found on host. GitHub operations inside the container may not work."
    else
      local token_output=""
      local token_stderr_file
      token_stderr_file=$(mktemp)
      if token_output=$(gh auth token 2>"$token_stderr_file"); then
        token_output=$(echo "$token_output" | tr -d '[:space:]')
        if [ -z "$token_output" ]; then
          warn "gh auth token returned empty token. GitHub operations inside the container may not work."
        else
          gh_token_env+=("--env" "GH_TOKEN=${token_output}")
        fi
      else
        local token_stderr
        token_stderr=$(cat "$token_stderr_file")
        warn "gh auth token failed: ${token_stderr}. GitHub operations inside the container may not work."
      fi
      rm -f "$token_stderr_file"
    fi
  fi

  local volume_name="oc-sandbox-home-${image_name}"

  # Build profile spec for env var
  local profile_spec="$profile"
  if [ -n "$profile_variant" ]; then
    profile_spec="${profile}:${profile_variant}"
  fi

  info "Starting opencode sandbox"
  echo "  Profile:   $profile_spec"
  echo "  Workspace: $workspace_path"
  echo "  Image:     $full_image"
  if [ "$debug" = "true" ]; then
    echo "  Debug:     /bin/bash"
  fi
  echo ""

  local container_cmd="opencode"
  if [ "$debug" = "true" ]; then
    container_cmd="/bin/bash"
  fi

  podman run \
    --rm \
    --interactive \
    --tty \
    --read-only \
    --tmpfs /tmp:rw,nosuid,size=100m \
    --volume "${volume_name}:/home/sandbox" \
    --user sandbox \
    --cap-drop ALL \
    --cap-add CHOWN \
    --security-opt no-new-privileges:true \
    --mount type=bind,src="${workspace_path}",dst=/workspace,relabel=private \
    --mount type=bind,src="${profile_path}",dst=/mnt/oc-sandbox-profiles,readonly,relabel=private \
    --mount type=bind,src="${config_file}",dst=/mnt/oc-sandbox-config/config,readonly,relabel=private \
    ${ssh_mounts[@]+"${ssh_mounts[@]}"} \
    ${auth_mount[@]+"${auth_mount[@]}"} \
    ${gitignore_mount[@]+"${gitignore_mount[@]}"} \
    ${gh_token_env[@]+"${gh_token_env[@]}"} \
    --env "OC_SANDBOX_PROFILE=${profile_spec}" \
    "$full_image" \
    "$container_cmd"
}

# Main dispatch
if [ $# -eq 0 ]; then
  usage_main
  exit 0
fi

case "$1" in
build)
  shift
  cmd_build "$@"
  ;;
run)
  shift
  cmd_run "$@"
  ;;
uninstall)
  shift
  cmd_uninstall "$@"
  ;;
completion)
  shift
  cmd_completion "$@"
  ;;
--help | -h)
  usage_main
  exit 0
  ;;
*)
  error "Unknown command: $1\nUse 'oc-sandbox --help' for usage information."
  ;;
esac
