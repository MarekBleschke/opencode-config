#!/usr/bin/env bash
set -euo pipefail

# oc-sandbox - Run opencode in a containerized sandbox
# Provides filesystem isolation and permission escalation protection

_resolve_script_dir() {
  local source="${BASH_SOURCE[0]}"
  while [ -L "$source" ]; do
    local dir
    dir="$(cd "$(dirname "$source")" && pwd -P)"
    source="$(readlink "$source")"
    [[ "$source" != /* ]] && source="$dir/$source"
  done
  SCRIPT_DIR="$(cd "$(dirname "$source")" && pwd -P)"
}
_resolve_script_dir
CONTAINERFILE="${SCRIPT_DIR}/Containerfile"
OPENCODE_INSTALL_SHA256_FILE="${SCRIPT_DIR}/opencode-install.sha256"
COMPLETION_ZSH="${SCRIPT_DIR}/completion_zsh"
IMAGE_BASE="localhost/opencode-sandbox"
DEFAULT_TAG="main"
DEFAULT_PROFILE="dev"

# Terminal colors
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

usage_main() {
  cat <<EOF
Usage: oc-sandbox <command> [options]

Commands:
    build       Build a container image
    run         Run opencode in a sandbox
    install     Install oc-sandbox as a global command
    uninstall   Uninstall the global oc-sandbox command
    completion  Generate shell completion scripts

Run 'oc-sandbox <command> --help' for more information on a command.

Examples:
    oc-sandbox build                        # Build image with default tag "main"
    oc-sandbox build --tag experiment       # Build image tagged "experiment"
    oc-sandbox run                           # Run with defaults (tag: main, profile: dev, path: .)
    oc-sandbox run --profile web-dev         # Use web-dev profile
    oc-sandbox run -p systems ~/projects/x   # Use systems profile, specific project dir
EOF
}

usage_build() {
  cat <<EOF
Usage: oc-sandbox build [OPTIONS]

Build a container image for the opencode sandbox.

Options:
    -t, --tag <TAG>      Tag for the built image (default: main)
    -f, --force          Force rebuild even if image already exists
    -h, --help           Show this help message
EOF
}

usage_run() {
  cat <<EOF
Usage: oc-sandbox run [OPTIONS] [PATH]

Run opencode in a containerized sandbox with filesystem isolation.

Options:
    -t, --tag <TAG>            Tag of the image to run (default: main)
    -p, --profile <NAME>      Opencode profile to activate (default: dev)
    --no-ssh                  Skip mounting SSH keys from host
    --no-auth                 Skip mounting auth.json from host
    --no-gh-token             Skip GH_TOKEN detection from host
    --gh-token <TOKEN>        Use the provided GitHub token instead of auto-detecting
    --debug                   Run /bin/bash instead of opencode for debugging
    -h, --help                Show this help message

Arguments:
    PATH   Directory to mount as /workspace (default: current working directory)

Examples:
    oc-sandbox run                           # Run with defaults
    oc-sandbox run --profile web-dev         # Use web-dev profile
    oc-sandbox run -p systems ~/projects/x   # Use systems profile, specific project dir
    oc-sandbox run --tag experiment          # Run the "experiment" tagged image
EOF
}

usage_install() {
  cat <<EOF
Usage: oc-sandbox install

Install oc-sandbox as a global command by creating a symlink in
~/.local/bin/ pointing to this script.

Options:
    --no-completions    Skip shell completion setup
    -h, --help          Show this help message

Examples:
    oc-sandbox install                  # Install with shell completions
    oc-sandbox install --no-completions  # Install without completions
EOF
}

usage_uninstall() {
  cat <<EOF
Usage: oc-sandbox uninstall

Uninstall the global oc-sandbox command by removing the symlink
from ~/.local/bin/. Also removes shell completion setup and cache.

Options:
    -h, --help    Show this help message

Examples:
    oc-sandbox uninstall    # Remove symlink, completions, and cache
EOF
}

usage_completion() {
  cat <<EOF
Usage: oc-sandbox completion <shell>

Generate shell completion scripts for oc-sandbox.

Shells:
    zsh         Generate Zsh completion script

Options:
    --refresh           Force-refresh the completion cache
    --tag <TAG>         Refresh cache for a specific tag only (used with --refresh)
    -h, --help          Show this help message

Examples:
    source <(oc-sandbox completion zsh)    # Enable Zsh completions
    oc-sandbox completion --refresh        # Manually refresh all cached data
    oc-sandbox completion --refresh --tag main  # Refresh cache for tag "main" only
EOF
}

cmd_install() {
  local no_completions="false"
  while [[ $# -gt 0 ]]; do
    case "$1" in
    --no-completions)
      no_completions="true"
      shift
      ;;
    -h | --help)
      usage_install
      exit 0
      ;;
    -*)
      error "Unknown option: $1\nUse 'oc-sandbox install --help' for usage information."
      ;;
    *)
      error "Unknown argument: $1\nUse 'oc-sandbox install --help' for usage information."
      ;;
    esac
  done

  local install_dir="${HOME}/.local/bin"
  local install_path="${install_dir}/oc-sandbox"
  local script_path="${SCRIPT_DIR}/oc-sandbox"

  # Create ~/.local/bin if it doesn't exist
  if [ ! -d "$install_dir" ]; then
    info "Creating ${install_dir}..."
    mkdir -p "$install_dir"
  fi

  # Check if already installed
  if [ -L "$install_path" ]; then
    local current_target
    current_target="$(readlink "$install_path")"
    if [ "$current_target" = "$script_path" ]; then
      info "Already installed at ${install_path}"
      # Still set up completions unless --no-completions was specified
      if [ "$no_completions" = "false" ]; then
        setup_completions
      fi
      exit 0
    else
      info "Updating symlink to point to ${script_path}..."
      ln -sf "$script_path" "$install_path"
      info "Updated ${install_path}"
    fi
  elif [ -e "$install_path" ]; then
    warn "Refusing to overwrite a regular file at ${install_path}"
    exit 1
  else
    ln -s "$script_path" "$install_path"
    info "Installed ${install_path}"
  fi

  # Set up shell completions (unless --no-completions)
  if [ "$no_completions" = "false" ]; then
    setup_completions
  fi

  # Warn if ~/.local/bin is not in PATH
  if [[ ":$PATH:" != *":${install_dir}:"* ]]; then
    warn "${install_dir} is not in PATH. Add it with:"
    warn "  export PATH=\"${install_dir}:\$PATH\""
  fi
}

cmd_uninstall() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
    -h | --help)
      usage_uninstall
      exit 0
      ;;
    -*)
      error "Unknown option: $1\nUse 'oc-sandbox uninstall --help' for usage information."
      ;;
    *)
      error "Unknown argument: $1\nUse 'oc-sandbox uninstall --help' for usage information."
      ;;
    esac
  done

  local install_path="${HOME}/.local/bin/oc-sandbox"
  local script_path="${SCRIPT_DIR}/oc-sandbox"

  if [ ! -e "$install_path" ] && [ ! -L "$install_path" ]; then
    info "Not installed at ${install_path}"
    exit 0
  fi

  if [ ! -L "$install_path" ]; then
    warn "Not a symlink, refusing to remove ${install_path}"
    exit 1
  fi

  local current_target
  current_target="$(readlink "$install_path")"
  if [ "$current_target" != "$script_path" ]; then
    warn "Symlink points to a different location, refusing to remove ${install_path}"
    exit 1
  fi

  rm "$install_path"
  info "Uninstalled ${install_path}"

  # Clean up shell completions
  cleanup_completions

  # Clean up completion cache
  cleanup_cache
}

error() {
  echo -e "${RED}Error: $1${NC}" >&2
  exit 1
}

warn() {
  echo -e "${YELLOW}Warning: $1${NC}" >&2
}

info() {
  echo -e "${GREEN}$1${NC}"
}

setup_completions() {
  local shell="$(basename "${SHELL:-}")"
  case "$shell" in
  zsh)
    local rc_file="${HOME}/.zshrc"
    local completion_line='source <(oc-sandbox completion zsh)'

    # Handle symlinked .zshrc
    if [ -L "$rc_file" ]; then
      info ".zshrc is a symlink; completions will be added to the target file"
    fi

    # Create .zshrc if it doesn't exist
    if [ ! -f "$rc_file" ]; then
      touch "$rc_file"
    fi

    # Check if completion line already exists (idempotent)
    if grep -qF "$completion_line" "$rc_file" 2>/dev/null; then
      info "Shell completions already set up in ${rc_file}"
    else
      echo '' >>"$rc_file"
      echo "$completion_line" >>"$rc_file"
      info "Added shell completions to ${rc_file}"
    fi
    ;;
  bash)
    warn "Bash completion is not yet implemented. See 'oc-sandbox completion --help' for available shells."
    ;;
  fish)
    warn "Fish completion is not yet implemented. See 'oc-sandbox completion --help' for available shells."
    ;;
  *)
    warn "Unknown shell '${shell}'. Add to your shell config: source <(oc-sandbox completion zsh)"
    ;;
  esac

  # Seed the completion cache
  oc-sandbox completion --refresh >/dev/null 2>&1 || true
}

cleanup_completions() {
  local shell="$(basename "${SHELL:-}")"
  case "$shell" in
  zsh)
    local rc_file="${HOME}/.zshrc"
    local completion_line='source <(oc-sandbox completion zsh)'

    if [ -f "$rc_file" ]; then
      if [ -L "$rc_file" ]; then
        info ".zshrc is a symlink; removing completions from the target file"
      fi

      # Remove the completion line
      local tmp_file
      tmp_file=$(mktemp)
      grep -vF "$completion_line" "$rc_file" >"$tmp_file" || true
      cat "$tmp_file" >"$rc_file"
      rm -f "$tmp_file"
      info "Removed shell completions from ${rc_file}"
    fi
    ;;
    # bash/fish: nothing to clean up (not implemented yet)
  esac
}

cleanup_cache() {
  local cache_dir="${HOME}/.cache/oc-sandbox"
  if [ -d "$cache_dir" ]; then
    rm -rf "$cache_dir" || warn "Could not remove cache directory ${cache_dir}"
    info "Removed completion cache from ${cache_dir}"
  fi
}

check_podman() {
  if ! command -v podman &>/dev/null; then
    error "podman not found. Please install podman."
  fi
}

# List available profiles from a container image
list_profiles() {
  local image_name="$1"
  local profiles
  profiles=$(podman run --rm "$image_name" ls -1 /home/sandbox/opencode-config/profiles/ 2>/dev/null | grep -v '^\.' || true)
  if [ -z "$profiles" ]; then
    echo "  (no profiles found)"
  else
    echo "$profiles" | while read -r profile; do
      echo "  - $profile"
    done
  fi
}

_refresh_profiles_for_tag() {
  local tag_name="$1"
  local cache_dir="$2"
  local now="$3"
  local image_name="${IMAGE_BASE}:${tag_name}"

  if podman image exists "$image_name" 2>/dev/null; then
    local profiles
    profiles=$(podman run --rm "$image_name" ls -1 /home/sandbox/opencode-config/profiles/ 2>/dev/null | grep -v '^\.' || true)
    echo "$profiles" >"$cache_dir/profiles-${tag_name}"
    echo "profiles-${tag_name}_timestamp=${now}" >>"$cache_dir/cache.meta"
  fi
}

cmd_completion_refresh() {
  local specific_tag="${1:-}"

  # Create cache directory if needed
  local cache_dir="${HOME}/.cache/oc-sandbox"
  mkdir -p "$cache_dir"

  # Check if podman is available
  if ! command -v podman &>/dev/null; then
    warn "podman not found. Cache refresh skipped."
    return 0
  fi

  local now
  now=$(date +%s)

  # Refresh images list
  local images
  images=$(podman images --format '{{.Repository}}:{{.Tag}}' 2>/dev/null | grep "^${IMAGE_BASE}:" | sed "s|^${IMAGE_BASE}:||" || true)
  echo "$images" >"$cache_dir/images"
  # Update images_timestamp while preserving profile timestamps
  local existing_profiles_ts=""
  if [[ -f "$cache_dir/cache.meta" ]]; then
    existing_profiles_ts=$(grep "^profiles-.*_timestamp=" "$cache_dir/cache.meta" 2>/dev/null || true)
  fi
  echo "images_timestamp=${now}" >"$cache_dir/cache.meta"
  if [[ -n "$existing_profiles_ts" ]]; then
    echo "$existing_profiles_ts" >>"$cache_dir/cache.meta"
  fi

  # Refresh profiles for specific tag or all tags
  if [ -n "$specific_tag" ]; then
    _refresh_profiles_for_tag "$specific_tag" "$cache_dir" "$now"
  else
    # Refresh profiles for all known tags
    local tag_name
    while IFS= read -r tag_name; do
      [ -z "$tag_name" ] && continue
      _refresh_profiles_for_tag "$tag_name" "$cache_dir" "$now"
    done <"$cache_dir/images"
  fi
}

cmd_completion_zsh() {
  cat $COMPLETION_ZSH
}

cmd_completion() {
  local refresh="false"
  local tag=""
  local shell_arg=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --refresh)
      refresh="true"
      shift
      ;;
    --tag)
      if [ -z "${2:-}" ]; then
        error "Option --tag requires a value."
      fi
      tag="$2"
      shift 2
      ;;
    -h | --help)
      usage_completion
      exit 0
      ;;
    -*)
      error "Unknown option: $1\nUse 'oc-sandbox completion --help' for usage information."
      ;;
    *)
      # Shell argument
      if [ -n "$shell_arg" ]; then
        error "Unknown argument: $1\nUse 'oc-sandbox completion --help' for usage information."
      fi
      shell_arg="$1"
      shift
      ;;
    esac
  done

  if [ "$refresh" = "true" ]; then
    cmd_completion_refresh "$tag"
    return
  fi

  if [ -z "${shell_arg:-}" ]; then
    error "Shell name required. Use 'oc-sandbox completion --help' for available shells."
  fi

  case "$shell_arg" in
  zsh)
    cmd_completion_zsh
    ;;
  bash)
    echo "Bash completion is not yet implemented. See 'oc-sandbox completion --help' for available shells."
    ;;
  fish)
    echo "Fish completion is not yet implemented. See 'oc-sandbox completion --help' for available shells."
    ;;
  *)
    error "Unknown shell '${shell_arg}'. Available shells: zsh"
    ;;
  esac
}

# Build subcommand
cmd_build() {
  local tag="$DEFAULT_TAG"
  local force="false"

  while [[ $# -gt 0 ]]; do
    case "$1" in
    -t | --tag)
      if [ -z "${2:-}" ]; then
        error "Option --tag requires a value."
      fi
      tag="$2"
      shift 2
      ;;
    -f | --force)
      force="true"
      shift
      ;;
    -h | --help)
      usage_build
      exit 0
      ;;
    -*)
      error "Unknown option: $1\nUse 'oc-sandbox build --help' for usage information."
      ;;
    *)
      error "Unknown argument: $1\nUse 'oc-sandbox build --help' for usage information."
      ;;
    esac
  done

  check_podman

  local image_name="${IMAGE_BASE}:${tag}"

  # Check if image already exists
  if podman image exists "$image_name" 2>/dev/null && [ "$force" != "true" ]; then
    info "Image ${image_name} already exists. Use --force to rebuild."
    exit 0
  fi

  # Validate Containerfile exists
  if [ ! -f "$CONTAINERFILE" ]; then
    error "Containerfile not found at: $CONTAINERFILE"
  fi

  # Read SHA256 checksum from file
  if [ ! -f "$OPENCODE_INSTALL_SHA256_FILE" ]; then
    error "Checksum file not found: $OPENCODE_INSTALL_SHA256_FILE"
  fi
  local sha256
  sha256=$(head -n 1 "$OPENCODE_INSTALL_SHA256_FILE" | tr -d '[:space:]')
  if [ -z "$sha256" ]; then
    error "Checksum file is empty: $OPENCODE_INSTALL_SHA256_FILE"
  fi

  info "Building container image ${image_name}..."
  if ! podman build \
    --build-arg "OPENCODE_INSTALL_SHA256=${sha256}" \
    -t "$image_name" \
    -f "$CONTAINERFILE" \
    "${SCRIPT_DIR}/.."; then
    error "Container build failed. See output above for details."
  fi

  # Remove the named volume for this tag so next run starts fresh
  local volume_name="opencode-sandbox-home-${tag}"
  if podman volume exists "$volume_name" 2>/dev/null; then
    info "Removing existing volume ${volume_name} to ensure fresh state..."
    podman volume rm "$volume_name" >/dev/null 2>&1 || true
  fi

  info "Image ${image_name} built successfully."

  # Refresh completion cache for the built tag
  oc-sandbox completion --refresh --tag "$tag" >/dev/null 2>&1 || true
}

# Run subcommand
cmd_run() {
  local tag="$DEFAULT_TAG"
  local profile="$DEFAULT_PROFILE"
  local workspace_path=""
  local no_ssh="false"
  local no_auth="false"
  local debug="false"
  local no_gh_token="false"
  local gh_token=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
    -t | --tag)
      if [ -z "${2:-}" ]; then
        error "Option --tag requires a value."
      fi
      tag="$2"
      shift 2
      ;;
    -p | --profile)
      if [ -z "${2:-}" ]; then
        error "Option --profile requires a value."
      fi
      profile="$2"
      shift 2
      ;;
    -h | --help)
      usage_run
      exit 0
      ;;
    --no-ssh)
      no_ssh="true"
      shift
      ;;
    --no-auth)
      no_auth="true"
      shift
      ;;
    --no-gh-token)
      no_gh_token="true"
      shift
      ;;
    --gh-token)
      if [ -z "${2:-}" ]; then
        error "Option --gh-token requires a value."
      fi
      gh_token="$2"
      shift 2
      ;;
    --debug)
      debug="true"
      shift
      ;;
    -*)
      error "Unknown option: $1\nUse 'oc-sandbox run --help' for usage information."
      ;;
    *)
      if [ -n "$workspace_path" ]; then
        error "Multiple paths specified. Only one PATH argument is allowed."
      fi
      workspace_path="$1"
      shift
      ;;
    esac
  done

  # Validate --no-gh-token / --gh-token conflict
  if [ "$no_gh_token" = "true" ] && [ -n "$gh_token" ]; then
    error "Cannot use --gh-token with --no-gh-token"
  fi

  check_podman

  local image_name="${IMAGE_BASE}:${tag}"

  # Check if image exists
  if ! podman image exists "$image_name" 2>/dev/null; then
    echo -e "${RED}Error: Image ${image_name} not found.${NC}" >&2
    echo "" >&2
    echo "Available images:" >&2
    local available_images
    available_images=$(podman images --format "{{.Repository}}:{{.Tag}}" | grep "^${IMAGE_BASE}:" || true)
    if [ -n "$available_images" ]; then
      echo "$available_images" | while read -r img; do
        echo "  - $img" >&2
      done
    else
      echo "  (no opencode-sandbox images found)" >&2
    fi
    error "Run 'oc-sandbox build' first to build an image."
  fi

  # Validate profile name doesn't contain path traversal characters
  if [[ "$profile" =~ [/\\.] ]]; then
    error "Profile name must not contain '/', '\\', or '.' characters."
  fi

  # Validate profile exists in the container image
  if ! podman run --rm "$image_name" test -d "/home/sandbox/opencode-config/profiles/$profile" 2>/dev/null; then
    echo -e "${RED}Error: Invalid profile: '$profile'${NC}" >&2
    echo "" >&2
    echo "Available profiles:" >&2
    list_profiles "$image_name" >&2
    exit 1
  fi

  # Default workspace path to current directory
  if [ -z "$workspace_path" ]; then
    workspace_path="$(pwd)"
  fi

  # Resolve to absolute path and validate existence
  if [ ! -e "$workspace_path" ]; then
    error "PATH does not exist: $workspace_path"
  fi

  if [ ! -d "$workspace_path" ]; then
    error "PATH is not a directory: $workspace_path"
  fi

  workspace_path="$(cd "$workspace_path" && pwd)"

  # Double-check after cd resolves symlinks
  if [ ! -d "$workspace_path" ]; then
    error "PATH is not a directory: $workspace_path"
  fi

  # Warn if path is outside home directory
  if [[ "$workspace_path" != "$HOME"* ]]; then
    warn "PATH is outside your home directory."
    if [ ! -t 0 ]; then
      error "PATH is outside home directory and stdin is not a terminal. Run from within your home directory."
    fi
    read -r -p "Continue? [y/N] " response
    if [[ "$response" != "y" && "$response" != "Y" ]]; then
      echo "Aborted."
      exit 0
    fi
  fi

  # SSH key auto-detection
  local ssh_mounts=()
  local ssh_key="${HOME}/.ssh/id_rsa"
  local ssh_pub_key="${HOME}/.ssh/id_rsa.pub"

  if [ "$no_ssh" = "true" ]; then
    info "Skipping SSH key mount (--no-ssh)"
  elif [ -e "$ssh_key" ]; then
    if [ ! -r "$ssh_key" ]; then
      error "Cannot read SSH key at ~/.ssh/id_rsa. Check file permissions."
    fi
    # Permission check (GNU stat uses -c, BSD/macOS stat uses -f)
    local mode
    mode=$(stat -c '%a' "$ssh_key" 2>/dev/null || stat -f '%Lp' "$ssh_key" 2>/dev/null)
    if [ -n "$mode" ] && [ $((0$mode & 077)) -ne 0 ]; then
      warn "SSH key at ~/.ssh/id_rsa has overly permissive permissions (0${mode})."
      warn "SSH may refuse to use it. Consider: chmod 600 ~/.ssh/id_rsa"
    fi
    ssh_mounts+=("--mount" "type=bind,src=${ssh_key},dst=/home/sandbox/.ssh/id_rsa,readonly,relabel=private")
    if [ -e "$ssh_pub_key" ]; then
      ssh_mounts+=("--mount" "type=bind,src=${ssh_pub_key},dst=/home/sandbox/.ssh/id_rsa.pub,readonly,relabel=private")
    fi
  else
    warn "SSH key not found at ~/.ssh/id_rsa. Git SSH operations may not work."
  fi

  # auth.json auto-detection
  local auth_mount=()
  local auth_json="${HOME}/.local/share/opencode/auth.json"

  if [ "$no_auth" = "true" ]; then
    info "Skipping auth.json mount (--no-auth)"
  elif [ -e "$auth_json" ]; then
    if [ ! -r "$auth_json" ]; then
      error "Cannot read auth.json at ~/.local/share/opencode/auth.json. Check file permissions."
    fi
    auth_mount+=("--mount" "type=bind,src=${auth_json},dst=/home/sandbox/.local/share/opencode/auth.json,readonly,relabel=private")
  else
    warn "auth.json not found at ~/.local/share/opencode/auth.json. Authenticated providers may not work."
  fi

  # GH_TOKEN auto-detection
  local gh_token_env=()

  if [ "$no_gh_token" = "true" ]; then
    info "Skipping GH_TOKEN detection (--no-gh-token)"
  elif [ -n "$gh_token" ]; then
    gh_token_env+=("--env" "GH_TOKEN=${gh_token}")
  else
    if ! command -v gh &>/dev/null; then
      warn "gh CLI not found on host. GitHub operations inside the container may not work."
    else
      local token_output=""
      local token_stderr_file
      token_stderr_file=$(mktemp)
      if token_output=$(gh auth token 2>"$token_stderr_file"); then
        token_output=$(echo "$token_output" | tr -d '[:space:]')
        if [ -z "$token_output" ]; then
          warn "gh auth token returned empty token. GitHub operations inside the container may not work."
        else
          gh_token_env+=("--env" "GH_TOKEN=${token_output}")
        fi
      else
        local token_stderr
        token_stderr=$(cat "$token_stderr_file")
        warn "gh auth token failed: ${token_stderr}. GitHub operations inside the container may not work."
      fi
      rm -f "$token_stderr_file"
    fi
  fi

  local volume_name="opencode-sandbox-home-${tag}"

  info "Starting opencode sandbox"
  echo "  Profile:   $profile"
  echo "  Workspace: $workspace_path"
  echo "  Image:     $image_name"
  if [ "$debug" = "true" ]; then
    echo "  Debug:     /bin/bash"
  fi
  echo ""

  local container_cmd="opencode"
  if [ "$debug" = "true" ]; then
    container_cmd="/bin/bash"
  fi

  podman run \
    --rm \
    --interactive \
    --tty \
    --read-only \
    --tmpfs /tmp:rw,nosuid,size=100m \
    --volume "${volume_name}:/home/sandbox" \
    --user sandbox \
    --cap-drop ALL \
    --cap-add CHOWN \
    --security-opt no-new-privileges:true \
    --mount type=bind,src="${workspace_path}",dst=/workspace,relabel=private \
    ${ssh_mounts[@]+"${ssh_mounts[@]}"} \
    ${auth_mount[@]+"${auth_mount[@]}"} \
    ${gh_token_env[@]+"${gh_token_env[@]}"} \
    --env "OPENCODE_CONFIG_DIR=/home/sandbox/opencode-config/profiles/${profile}" \
    "$image_name" \
    "$container_cmd"
}

# Main dispatch
if [ $# -eq 0 ]; then
  usage_main
  exit 0
fi

case "$1" in
build)
  shift
  cmd_build "$@"
  ;;
run)
  shift
  cmd_run "$@"
  ;;
install)
  shift
  cmd_install "$@"
  ;;
uninstall)
  shift
  cmd_uninstall "$@"
  ;;
completion)
  shift
  cmd_completion "$@"
  ;;
--help | -h)
  usage_main
  exit 0
  ;;
