FROM ubuntu:24.04

# Avoid interactive prompts during package installation
ENV DEBIAN_FRONTEND=noninteractive

# Install system dependencies and clean up in a single layer to reduce image size
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        git \
        curl \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install opencode CLI
# The SHA256 hash must be provided at build time for security
# To get the hash: curl -fsSL https://opencode.ai/install.sh | sha256sum
ARG OPENCODE_INSTALL_SHA256
RUN curl -fsSL https://opencode.ai/install.sh -o /tmp/install.sh && \
    if [ -n "${OPENCODE_INSTALL_SHA256}" ]; then \
        echo "${OPENCODE_INSTALL_SHA256}  /tmp/install.sh" | sha256sum -c - ; \
    else \
        echo "ERROR: OPENCODE_INSTALL_SHA256 build arg must be set" >&2 ; \
        exit 1 ; \
    fi && \
    bash /tmp/install.sh && \
    rm /tmp/install.sh

# Ensure opencode is in PATH
ENV PATH="/home/sandbox/.local/bin:${PATH}"

# Create sandbox user, clone repo, run bootstrap, set ownership in one layer
RUN groupadd -g 1000 sandbox && \
    useradd -m -u 1000 -g 1000 -s /bin/bash sandbox && \
    git clone https://github.com/MarekBleschke/opencode-config.git /home/sandbox/opencode-config && \
    /home/sandbox/opencode-config/sandbox/bootstrap.sh && \
    chown -R sandbox:sandbox /home/sandbox

# Set working directory to /workspace (will be bind-mounted at runtime)
WORKDIR /workspace

# Run as sandbox user by default
USER sandbox

# Default command
CMD ["opencode"]
