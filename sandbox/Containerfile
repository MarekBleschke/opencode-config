FROM ubuntu:24.04

# Avoid interactive prompts during package installation
ENV DEBIAN_FRONTEND=noninteractive

# Install system dependencies and clean up in a single layer to reduce image size
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        git \
        curl \
        ca-certificates \
        golang-go \
    && rm -rf /var/lib/apt/lists/*

# Create sandbox user (using UID/GID 1001 to avoid conflicts with system users)
RUN groupadd -g 1001 sandbox && \
    useradd -m -u 1001 -g 1001 -s /bin/bash sandbox

# Switch to sandbox user for installations
USER sandbox

# Install opencode CLI using go install
# This installs to /home/sandbox/go/bin
RUN go install github.com/opencode-ai/opencode@latest

# Ensure opencode is in PATH
ENV PATH="/home/sandbox/go/bin:${PATH}"

# Copy the local opencode-config repository into the image
# This is done as root first so we can run the bootstrap script
USER root
COPY --chown=sandbox:sandbox . /home/sandbox/opencode-config/

# Run bootstrap script as sandbox user
USER sandbox
RUN /home/sandbox/opencode-config/sandbox/bootstrap.sh

# Set working directory to /workspace (will be bind-mounted at runtime)
WORKDIR /workspace

# Default command
CMD ["opencode"]
