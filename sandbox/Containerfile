FROM ubuntu:24.04

# Avoid interactive prompts during package installation
ENV DEBIAN_FRONTEND=noninteractive

# Install system dependencies and clean up in a single layer to reduce image size
RUN apt-get update && \
  apt-get install -y --no-install-recommends \
  git \
  golang-go \
  curl \
  ca-certificates \
  openssh-client \
  zsh \
  && rm -rf /var/lib/apt/lists/*

# Install GitHub CLI
RUN mkdir -p -m 755 /etc/apt/keyrings && \
  curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg -o /etc/apt/keyrings/githubcli-archive-keyring.gpg && \
  chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg && \
  echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | tee /etc/apt/sources.list.d/github-cli.list > /dev/null && \
  apt-get update && \
  apt-get install -y --no-install-recommends gh && \
  rm -rf /var/lib/apt/lists/*

# Install opencode CLI with checksum verification
ARG OPENCODE_INSTALL_SHA256
ARG GIT_USER_NAME=""
ARG GIT_USER_EMAIL=""
ARG GITIGNORE_CONTENT=""
ARG MODEL_SUPERPOWERS_BRAINSTORM=""
ARG MODEL_SUPERPOWERS_PLANNER=""
ARG MODEL_SUPERPOWERS_DEBUGGER=""
ARG MODEL_SUPERPOWERS_EXECUTION_ORCHESTRATOR=""
ARG MODEL_SUPERPOWERS_SOFTWARE_ENGINEER=""
ARG MODEL_SUPERPOWERS_SENIOR_SOFTWARE_ENGINEER=""
ARG MODEL_SUPERPOWERS_CODE_REVIEWER=""
ARG MODEL_SUPERPOWERS_SPEC_REVIEWER=""
ARG MODEL_SUPERPOWERS_UTILITY=""
RUN curl -fsSL https://opencode.ai/install -o /tmp/install.sh && \
  if [ -n "${OPENCODE_INSTALL_SHA256}" ]; then \
  echo "${OPENCODE_INSTALL_SHA256}  /tmp/install.sh" | sha256sum -c - ; \
  else \
  echo "ERROR: OPENCODE_INSTALL_SHA256 build arg must be set" >&2 ; \
  exit 1 ; \
  fi && \
  bash /tmp/install.sh && \
  rm /tmp/install.sh && \
  cp /root/.opencode/bin/opencode /usr/local/bin/opencode && \
  chmod +x /usr/local/bin/opencode

# Create sandbox user (using UID/GID 1001 to avoid conflicts with system users)
RUN groupadd -g 1001 sandbox && \
  useradd -m -u 1001 -g 1001 -s /bin/bash sandbox

# Pre-configure GitHub SSH host keys so git+ssh works without interactive prompt
RUN mkdir -p /home/sandbox/.ssh && \
  ssh-keyscan github.com >> /home/sandbox/.ssh/known_hosts && \
  chown -R sandbox:sandbox /home/sandbox/.ssh

# Create directory structure for runtime bind mounts (SSH keys, auth config)
# Must set ownership to sandbox:sandbox so the user can write to these directories
RUN mkdir -p /home/sandbox/.local/share/opencode && \
  chown -R sandbox:sandbox /home/sandbox/.local

# Copy the local oc-sandbox repository into the image
COPY --chown=sandbox:sandbox . /home/sandbox/oc-sandbox/

# Configure git to trust the repository directory and run bootstrap script as root
RUN git config --global --add safe.directory /home/sandbox/oc-sandbox && \
  GIT_USER_NAME="$GIT_USER_NAME" \
  GIT_USER_EMAIL="$GIT_USER_EMAIL" \
  GITIGNORE_CONTENT="$GITIGNORE_CONTENT" \
  MODEL_SUPERPOWERS_BRAINSTORM="$MODEL_SUPERPOWERS_BRAINSTORM" \
  MODEL_SUPERPOWERS_PLANNER="$MODEL_SUPERPOWERS_PLANNER" \
  MODEL_SUPERPOWERS_DEBUGGER="$MODEL_SUPERPOWERS_DEBUGGER" \
  MODEL_SUPERPOWERS_EXECUTION_ORCHESTRATOR="$MODEL_SUPERPOWERS_EXECUTION_ORCHESTRATOR" \
  MODEL_SUPERPOWERS_SOFTWARE_ENGINEER="$MODEL_SUPERPOWERS_SOFTWARE_ENGINEER" \
  MODEL_SUPERPOWERS_SENIOR_SOFTWARE_ENGINEER="$MODEL_SUPERPOWERS_SENIOR_SOFTWARE_ENGINEER" \
  MODEL_SUPERPOWERS_CODE_REVIEWER="$MODEL_SUPERPOWERS_CODE_REVIEWER" \
  MODEL_SUPERPOWERS_SPEC_REVIEWER="$MODEL_SUPERPOWERS_SPEC_REVIEWER" \
  MODEL_SUPERPOWERS_UTILITY="$MODEL_SUPERPOWERS_UTILITY" \
  /home/sandbox/oc-sandbox/sandbox/bootstrap.sh

# Switch to sandbox user
USER sandbox

RUN touch ~/.zshrc

# Set working directory to /workspace (will be bind-mounted at runtime)
WORKDIR /workspace

# Default command
CMD ["opencode"]
