{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "gh *": "ask",
      "gh pr *": "allow",
    },
    "external_directory": {
      "*": "ask",
      "/home/sandbox/opencode-config/submodules/*": "allow",
      "/tmp": "allow",
      "/tmp/*": "allow",
      "/private/tmp": "allow",
      "/private/tmp/*": "allow",
      "env:$TMPDIR": "allow",
      "env:$TMPDIR/*": "allow"
    },
  },
  "watcher": {
    "ignore": [
      ".git/**",
      "node_modules/**",
      "dist/**",
      "build/**",
      ".next/**",
      "coverage/**",
    ]
  }
}
